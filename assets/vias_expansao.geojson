{ "type": "Feature", "properties": { "fid": 2, "PopupInfo": "Centro - São Cristóvão", "layer": "Vetor 02", "Informações": "A segunda via de expansão, denominada eixo CEntro – São Cristóvão, teve início a partir da Ponte José Sarney. O trajeto segue pela Avenida Marechal Castelo Branco, Avenida Colares Moreira e Avenida Jerônimo de Albuquerque até alcançar a Avenida Guajajaras. Esse eixo consolidou um novo direcionamento do crescimento urbano na Ilha do Maranhão." }, "geometry": { "type": "MultiLineString", "coordinates": [ [ [ -44.30270756799996, -2.524967768999943, 0.0 ], [ -44.303130032999945, -2.523476507999931, 0.0 ], [ -44.303498056999956, -2.521787573999973, 0.0 ], [ -44.303846652999937, -2.519966175999969, 0.0 ], [ -44.304214411999965, -2.518309176999935, 0.0 ], [ -44.304350051999961, -2.517069178999975, 0.0 ], [ -44.304443239999955, -2.516242023999951, 0.0 ], [ -44.304213551999965, -2.514512532999959, 0.0 ], [ -44.303842926999948, -2.512913332999972, 0.0 ], [ -44.303732605999983, -2.511722346999932, 0.0 ], [ -44.303510888999938, -2.510581483999943, 0.0 ], [ -44.303376619999938, -2.509456734999958, 0.0 ], [ -44.303123271999937, -2.508965064999927, 0.0 ], [ -44.302691151999966, -2.508472065999968, 0.0 ], [ -44.302450559999954, -2.508268026999929, 0.0 ], [ -44.302054322999936, -2.508268692999934, 0.0 ], [ -44.300866179999957, -2.507810805999952, 0.0 ], [ -44.299924562999934, -2.507497004999948, 0.0 ], [ -44.297871103999967, -2.507170422999934, 0.0 ], [ -44.296775730999968, -2.506785259999958, 0.0 ], [ -44.296165704999964, -2.506486786999972, 0.0 ], [ -44.295314023999936, -2.505653741999936, 0.0 ], [ -44.293086991999985, -2.50381105699995, 0.0 ], [ -44.29233097599996, -2.503102920999936, 0.0 ], [ -44.291609731999984, -2.502459299999941, 0.0 ], [ -44.290281625999967, -2.501647242999979, 0.0 ], [ -44.288098703999935, -2.500701264999975, 0.0 ], [ -44.286595815999931, -2.50008934899995, 0.0 ], [ -44.285271403999957, -2.499630984999953, 0.0 ], [ -44.284321162999959, 