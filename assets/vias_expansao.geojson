{ "type": "Feature", "properties": { "fid": 3, "PopupInfo": "Centro - Bairro Araçagy", "layer": "Vetor 03", "Informações": "A terceira via de expansão ocorreu no sentido Centro – Araçagy, desenvolvendo-se mais ao norte da Ilha do Maranhão. Esse processo foi impulsionado pela duplicação da Avenida dos Holandeses (MA-203), estendendo-se pelo Araçagy até o município da Raposa." }, "geometry": { "type": "MultiLineString", "coordinates": [ [ [ -44.302714292999951, -2.52446615599996, 0.0 ], [ -44.303820062999932, -2.518917790999978, 0.0 ], [ -44.304142252999952, -2.516057603999968, 0.0 ], [ -44.303908735999983, -2.511765174999937, 0.0 ], [ -44.303330094999978, -2.507934431999956, 0.0 ], [ -44.304291887999966, -2.50554864999998, 0.0 ], [ -44.304563471999984, -2.503419747999942, 0.0 ], [ -44.305471962999945, -2.501551363999965, 0.0 ], [ -44.306994552999981, -2.500106435999953, 0.0 ], [ -44.30764600599997, -2.499233931999925, 0.0 ], [ -44.308240289999958, -2.49777560299998, 0.0 ], [ -44.306556713999953, -2.494993183999952, 0.0 ], [ -44.30457114799998, -2.49230339099995, 0.0 ], [ -44.303111231999935, -2.490527575999977, 0.0 ], [ -44.300268600999971, -2.490083292999941, 0.0 ], [ -44.297880695999936, -2.490545037999937, 0.0 ], [ -44.292899696999939, -2.492246790999957, 0.0 ], [ -44.290622699999972, -2.493043378999971, 0.0 ], [ -44.287045891999981, -2.493098722999946, 0.0 ], [ -44.283607567999979, -2.493414554999958, 0.0 ], [ -44.280737872999964, -2.49342964799996, 0.0 ], [ -44.276904505999937, -2.493725498999936, 0.0 ], [ -44.273077016999935, -2.493756849999954, 0.0 ], [ -44.270353481999962, -2.49373563599994, 0.0 ], [ -44.268850810999936, -2.493871261999971, 0.0 ], [ -44.266409346999978, -2.493122335999942, 0.0 ], [ -44.263404449999939, -2.492543145999946, 0.0 ], [ -44.261624769999969, -2.49224702999993, 0.0 ], [ -44.260255901999983, -2.491643014999966, 0.0 ], [ -44.256817128999955, -2.491051157999948, 0.0 ], [ -44.253361138999935, -2.48974596499994, 0.0 ], [ -44.2504518099999